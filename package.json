{
  "name": "revu-vscode",
  "displayName": "revu",
  "description": "Annotate code, export reviews to AI",
  "version": "1.0.0",
  "publisher": "kud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kud/revu-vscode"
  },
  "homepage": "https://marketplace.visualstudio.com/items?itemName=kud.revu-vscode",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/revu-logo.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "revu.addComment",
        "title": "Add Annotation",
        "category": "revu",
        "icon": "$(comment-add)"
      },
      {
        "command": "revu.createNote",
        "title": "Add Annotation",
        "category": "revu",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "revu.copyToClipboard",
        "title": "Copy to Clipboard",
        "category": "revu",
        "icon": "$(clippy)"
      },
      {
        "command": "revu.exportReview",
        "title": "Send to Copilot",
        "category": "revu",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "revu.exportMarkdown",
        "title": "Export as Markdown",
        "category": "revu",
        "icon": "$(markdown)"
      },
      {
        "command": "revu.clearComments",
        "title": "Clear All Annotations",
        "category": "revu",
        "icon": "$(trash)"
      },
      {
        "command": "revu.cycleView",
        "title": "Cycle View Mode",
        "category": "revu",
        "icon": "$(list-tree)"
      },
      {
        "command": "revu.editAnnotation",
        "title": "Edit Annotation",
        "category": "revu",
        "icon": "$(edit)"
      },
      {
        "command": "revu.saveAnnotation",
        "title": "Save Annotation",
        "category": "revu"
      },
      {
        "command": "revu.cancelAnnotation",
        "title": "Cancel Edit",
        "category": "revu"
      }
    ],
    "keybindings": [
      {
        "command": "revu.addComment",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "revu",
          "title": "revu",
          "icon": "assets/revu-icon.svg"
        }
      ]
    },
    "views": {
      "revu": [
        {
          "id": "revu.notes",
          "name": "Notes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "revu.notes",
        "contents": "No annotations yet.\n\nSelect any line in the editor and add an annotation.\n[Add Annotation](command:revu.addComment)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "revu.addComment",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "revu.addComment",
          "group": "revu"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "revu.createNote",
          "when": "commentController == revu && !comment",
          "group": "inline"
        }
      ],
      "comments/comment/title": [
        {
          "command": "revu.editAnnotation",
          "group": "inline",
          "when": "commentController == revu && comment == revuAnnotation"
        }
      ],
      "comments/comment/context": [
        {
          "command": "revu.saveAnnotation",
          "group": "inline@1",
          "when": "commentController == revu && comment == revuAnnotation"
        },
        {
          "command": "revu.cancelAnnotation",
          "group": "inline@2",
          "when": "commentController == revu && comment == revuAnnotation"
        }
      ],
      "view/title": [
        {
          "command": "revu.cycleView",
          "group": "navigation@1",
          "when": "view == revu.notes"
        },
        {
          "command": "revu.copyToClipboard",
          "group": "navigation@2",
          "when": "view == revu.notes"
        },
        {
          "command": "revu.exportReview",
          "group": "navigation@3",
          "when": "view == revu.notes"
        },
        {
          "command": "revu.exportMarkdown",
          "group": "navigation@4",
          "when": "view == revu.notes"
        },
        {
          "command": "revu.clearComments",
          "group": "navigation@5",
          "when": "view == revu.notes"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -f build/*.vsix",
    "package": "vsce package --no-dependencies --out build/",
    "install-ext": "npm run build && npm run clean && npm run package && code --install-extension build/revu-vscode-*.vsix --force",
    "release:patch": "npm version patch --no-git-tag-version && V=$(node -p \"require('./package.json').version\") && git add package.json package-lock.json && git commit -m \"🔖 chore(release): bump to $V\" && git tag \"v$V\" && git push && git push --tags && echo \"Bumped to v$V\"",
    "release:minor": "npm version minor --no-git-tag-version && V=$(node -p \"require('./package.json').version\") && git add package.json package-lock.json && git commit -m \"🔖 chore(release): bump to $V\" && git tag \"v$V\" && git push && git push --tags && echo \"Bumped to v$V\"",
    "release:major": "npm version major --no-git-tag-version && V=$(node -p \"require('./package.json').version\") && git add package.json package-lock.json && git commit -m \"🔖 chore(release): bump to $V\" && git tag \"v$V\" && git push && git push --tags && echo \"Bumped to v$V\"",
    "marketplace": "npm run build && npm run package && open https://marketplace.visualstudio.com/manage/publishers/kud"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "3.7.1",
    "esbuild": "^0.28",
    "typescript": "^6"
  }
}
