{
  "name": "revu-vscode",
  "displayName": "revu",
  "description": "Annotate code, export reviews to AI",
  "version": "0.1.0",
  "publisher": "kud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kud/revu-vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/revu-logo.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "revu.addComment",
        "title": "Add Comment",
        "category": "revu",
        "icon": "$(comment-add)"
      },
      {
        "command": "revu.exportReview",
        "title": "Export Review",
        "category": "revu",
        "icon": "$(export)"
      },
      {
        "command": "revu.clearComments",
        "title": "Clear All Comments",
        "category": "revu",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "revu",
          "title": "revu",
          "icon": "assets/revu-icon.svg"
        }
      ]
    },
    "views": {
      "revu": [
        {
          "id": "revu.notes",
          "name": "Notes"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "revu.addComment",
          "group": "navigation",
          "when": "editorFocus"
        },
        {
          "command": "revu.exportReview",
          "group": "navigation",
          "when": "editorFocus"
        }
      ],
      "editor/context": [
        {
          "command": "revu.addComment",
          "group": "revu"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "install-ext": "npm run build && npm run package && code --install-extension revu-vscode-*.vsix"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "3.7.1",
    "esbuild": "^0.25",
    "typescript": "^5"
  }
}
